<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Selenium Grid Suite" parallel="tests" thread-count="3">

    <test name="Chrome Test 1">
        <parameter name="browser" value="chrome"/>
        <classes><class name="tests.LoginTest"/></classes>
    </test>

    <test name="Firefox Test 1">
        <parameter name="browser" value="firefox"/>
        <classes><class name="tests.CartTest"/></classes>
    </test>

    <test name="Chrome Test 2">
        <parameter name="browser" value="chrome"/>
        <classes><class name="tests.CartTest"/></classes>
    </test>
</suite>
